{
  "name": "repo-lens",
  "type": "module",
  "version": "1.4.1",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "description": "Search GitHub repos. Open any README in a structured, readable view.",
  "author": {
    "name": "Robert Wang",
    "email": "glorywong1001@gmail.com"
  },
  "index": "./dist/index.js",
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/repolens#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/robertwang1001/repolens.git"
  },
  "bugs": "https://github.com/robertwang1001/repolens/issues",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "LOG_LEVEL=debug vercel env pull .env && react-router dev --port=3000",
    "prepare": "pnpm simple-git-hooks",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/react": "^11.14.0",
    "@react-router/fs-routes": "^7.17.0",
    "@react-router/node": "7.17.0",
    "@react-router/serve": "7.17.0",
    "@shikijs/rehype": "^4.2.0",
    "async-wait-until": "^2.0.31",
    "isbot": "^5.1.42",
    "logtape-easy": "^1.1.0",
    "lru-cache": "^11.5.1",
    "mdast-util-toc": "^7.1.0",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router": "7.17.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-github": "^12.0.0",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-parse": "^11.0.0",
    "shiki": "^4.2.0",
    "timeago.js": "^4.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint-react/eslint-plugin": "^5.8.18",
    "@react-router/dev": "7.17.0",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lint-staged": "^17.0.7",
    "renovate": "^43.220.0",
    "simple-git-hooks": "^2.13.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vercel": "^54.12.0",
    "vite": "^8.0.16"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit ${1}"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  }
}
